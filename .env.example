# Provider selection (offline defaults work with no keys)
LLM_PROVIDER=stub            # stub | anthropic | gemini | openai
EMBEDDING_PROVIDER=hash      # hash | openai | gemini

# Retrieval / chunking
TOP_K=3
CHUNK_SIZE=400               # characters per chunk
CHUNK_OVERLAP=40

# API keys (only needed for the matching provider)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Model overrides (optional)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
